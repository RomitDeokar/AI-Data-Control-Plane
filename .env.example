# Copy to .env and adjust. All values have sane defaults for local dev.
DATABASE_URL=postgresql://kestra:k3str4@localhost:5432/kestra
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
QDRANT_URL=http://localhost:6333
KESTRA_URL=http://localhost:8080

# embeddings
EMBEDDING_DIM=256
EMBEDDING_MODEL=hashing-tfidf-v1

# quality gate thresholds
GATE_COMPLETENESS_MIN=0.95
GATE_UNIQUENESS_MIN=0.99
GATE_EMBEDDING_COVERAGE_MIN=0.98
GATE_DRIFT_MAX=0.25
GATE_MIN_RECORDS=1
