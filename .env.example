# Copy to .env and adjust. All values have sane defaults for local dev.
# NOTE: docker compose --env-file does NOT strip inline comments, so every
# comment here lives on its own line and every value is bare (no trailing "#...").
DATABASE_URL=postgresql://kestra:k3str4@localhost:5432/kestra
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
QDRANT_URL=http://localhost:6333
KESTRA_URL=http://localhost:8080

# embeddings
EMBEDDING_DIM=256
EMBEDDING_MODEL=hashing-tfidf-v1

# quality gate thresholds
GATE_COMPLETENESS_MIN=0.95
GATE_UNIQUENESS_MIN=0.99
GATE_EMBEDDING_COVERAGE_MIN=0.98
GATE_DRIFT_MAX=0.25
GATE_MIN_RECORDS=1
# dedicated knob (was coupled to completeness)
GATE_VALIDATION_PASS_RATE_MIN=0.95

# event bus reliability
EVENT_STREAM=cp:events
# how long a duplicate upload is remembered (seconds)
IDEMPOTENCY_TTL_SECONDS=86400
# how long a dispatch marker lives before the relay may re-fire (seconds)
DISPATCH_TTL_SECONDS=86400
# relay dead-letters an event after N failed re-tries
EVENT_MAX_DELIVERIES=3
# events the relay drains per tick
RELAY_BATCH_SIZE=50

# security — shared secret for the Kestra webhook trigger (used by gateway + relay + flow)
CONTROLPLANE_WEBHOOK_KEY=controlplane-webhook-key
# API key required on mutating gateway endpoints (upload/webhook/rollback/reset).
# Leave blank to disable auth (open demo mode); set a value to require the
# `X-API-Key` header on writes.
CONTROLPLANE_API_KEY=
# comma-separated list of allowed CORS origins (default: same-origin only).
# Use "*" only for a throwaway public demo.
CORS_ALLOW_ORIGINS=
